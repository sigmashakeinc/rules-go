[16.098258, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;231m●\u001b[1C\u001b[39mThe system's security hook\u001b[1Cis\u001b[1Cblocking\u001b[1Cthis\u001b[1Cchange\u001b[1Cbecause\u001b[1Cthe\u001b[1Cquery\u001b[1Cin\u001b[1Cthe\u001b[1Ccomment\u001b[1Cuses\u001b[1C\u001b[38;5;153mfmt.Sprintf()\u001b[1C\u001b[39mto\u001b[1Cbuild\u001b[1Ca\u001b[1CSQL\u001b[1Cquery,\u001b[1Cwhich\u001b[1Cenables\u001b[1CSQL\u001b[1Cinjection\u001b[1Cvulnerabilities.\r\r\r\n\r\r\n\r\r\n\r\r\n\r\r\n\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[16.208538, "o", "\u001b]0;⠐ Replace TODO with query in main.go\u0007"]
[16.300733, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  The hook recommends using parameterized queries instead. Would you like me to:                                                                                                 \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[16.517751, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  1. Use a secure parameterized query: \u001b[38;5;153mrows, err := db.Query(\"SELECT * FROM users WHERE name = ?\", name)\u001b[39m                                                                         \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
