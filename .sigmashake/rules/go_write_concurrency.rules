# go_write_concurrency.rules — Go concurrency safety rules.
# Technology: go | Capability: write
# Covers: mutex usage, channel patterns, context propagation, data races.

rule no-mutex-copy {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*.go" AND content LINE_REGEX "sync\\.Mutex" AND content LINE_REGEX ":?=\\s*[a-zA-Z_][a-zA-Z0-9_]*\\s*$"
  MESSAGE "sync.Mutex must not be copied after first use — copying a locked mutex causes a deadlock. Use a pointer receiver (*MyStruct) or pass by pointer."
}

rule no-channel-without-close {
  enabled true
  priority 70
  severity warning
  LOG write
  IF path GLOB "**/*.go" AND content LINE_REGEX "make\\s*\\(\\s*chan\\s+"
  MESSAGE "Channel created. Ensure the sending goroutine closes it (or uses a done channel) to prevent receiving goroutines from blocking forever."
}

rule no-context-in-struct {
  enabled true
  priority 85
  severity warning
  LOG write
  IF path GLOB "**/*.go" AND content LINE_REGEX "context\\.Context" AND content LINE_REGEX "type\\s+[A-Z][a-zA-Z0-9]+\\s+struct"
  MESSAGE "context.Context should not be stored in a struct — it should flow through function parameters. Store context in structs only for request-scoped objects where it is the canonical approach."
}

rule no-select-without-default-or-timeout {
  enabled true
  priority 65
  severity warning
  LOG write
  IF path GLOB "**/*.go" AND content LINE_REGEX "select\\s*\\{" AND content NOT LINE_REGEX "case\\s*<-ctx\\.Done" AND content NOT LINE_REGEX "default:"
  MESSAGE "select statement without timeout or context cancellation can block indefinitely. Add a 'case <-ctx.Done():' or 'default:' branch to prevent goroutine leaks."
}

rule no-time-sleep-in-production {
  enabled true
  priority 75
  severity warning
  LOG write
  IF path GLOB "**/*.go" AND content LINE_REGEX "time\\.Sleep\\(" AND path NOT GLOB "*_test.go"
  MESSAGE "time.Sleep() in non-test code often indicates a polling anti-pattern. Prefer channels, sync primitives, or ticker-based approaches for coordination."
}
